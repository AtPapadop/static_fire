# ws_server configuration file
# Format: key=value
# Lines starting with # or ; are comments.

# Server configuration
ws_port=8080
max_clients=128
read_only=false
tick_ms=5

# Logging configuration
logging=false
log_dir=/var/log/simple_ws

# CAN configuration
auto_config_can=true
can_bitrate=1000000
can_ifname=can0
